# ============================================
# fake-commit CLI 使用说明
# ============================================
# CLI 使用方式:
# fc -n "用户名" -e "email@example.com" -s 2026-01-01 -d 2026-01-31
# fc -n "test" -e "test@test.com" -s 2026-01-01 -d 2026-01-05 -c 2

# ============================================
# fake-commit 环境变量配置
# ============================================

# ---------- 必需配置 ----------
# Git 提交用户名（必填）
FAKE_AUTHOR_NAME=your-name

# Git 提交邮箱（必填）
FAKE_AUTHOR_EMAIL=your@email.com

# ---------- 提交生成配置 ----------
# 生成提交的开始日期（格式：YYYY-MM-DD）
FAKE_START_DATE=2026-01-01

# 生成提交的结束日期（格式：YYYY-MM-DD）
FAKE_END_DATE=2026-01-31

# 提交目标分支名称
FAKE_BRANCH=main

# ---------- 固定提交模式 ----------
# 每天固定提交次数（当随机模式关闭时生效）
# 默认值：1
FAKE_COMMITS_PER_DAY=1

# ---------- 随机提交模式 ----------
# 是否启用随机提交模式（true/false）
# 默认值：false
FAKE_RANDOM=false

# 每天提交次数的随机区间（格式：min,max）
# 仅在随机模式开启时生效
# 默认值：1,10
FAKE_RANDOM_RANGE=1,10

# ============================================
# 使用说明
# ============================================
# 1. 固定模式（默认）：
#    - FAKE_RANDOM=false + FAKE_COMMITS_PER_DAY=3
#      表示每天固定生成 3 次提交
#
# 2. 随机模式：
#    - FAKE_RANDOM=true + FAKE_RANDOM_RANGE=1,10
#      表示每天随机生成 1~10 次提交